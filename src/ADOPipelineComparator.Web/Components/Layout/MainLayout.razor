@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudAvatar Color="Color.Dark" Size="Size.Small" Class="ml-2" Style="font-size:11px;font-weight:700;background:rgba(255,255,255,0.2)">AC</MudAvatar>
        <MudText Typo="Typo.h6" Class="ml-2">ADO Pipeline Comparator v@(_appVersion) by SIMS tech</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Mini" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudDrawerHeader Class="pa-2" Style="min-height:64px">
            <div class="d-flex align-center" style="gap:10px;overflow:hidden">
                <MudAvatar Color="Color.Primary" Style="font-size:12px;font-weight:700;flex-shrink:0">AC</MudAvatar>
                @if (_drawerOpen)
                {
                    <div style="overflow:hidden">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;line-height:1.3;white-space:nowrap">ADO Pipeline</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="line-height:1.2;white-space:nowrap">Comparator</MudText>
                    </div>
                }
            </div>
        </MudDrawerHeader>
        <NavMenu />
        <MudSpacer />
        <MudDivider />
        <div class="pa-2 d-flex align-center" style="gap:8px;min-height:52px">
            <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Size="Size.Small" Color="Color.Primary" Style="flex-shrink:0" />
            @if (_drawerOpen)
            {
                <div style="overflow:hidden">
                    <MudText Typo="Typo.caption" Style="font-weight:600;line-height:1.2;white-space:nowrap">v@(_appVersion) &bull; SIMS tech</MudText>
                </div>
            }
        </div>
    </MudDrawer>

    <MudMainContent>
        <div class="pa-4">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private bool _drawerOpen = true;
    private string _appVersion = string.Empty;

    protected override void OnInitialized()
    {
        var ver = GetType().Assembly.GetName().Version;
        _appVersion = ver is null ? "?" : $"{ver.Major}.{ver.Minor}.{ver.Build}";
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
